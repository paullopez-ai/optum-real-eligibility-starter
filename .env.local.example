# Optum API — Sandbox Credentials
# Obtain by registering at: https://marketplace.optum.com/apiservices/api-sandbox-access
OPTUM_CLIENT_ID=your_sandbox_client_id_here
OPTUM_CLIENT_SECRET=your_sandbox_client_secret_here
OPTUM_AUTH_URL=https://idx.linkhealth.com/auth/realms/developer-platform/protocol/openid-connect/token
OPTUM_ELIGIBILITY_URL=https://sandbox-apigw.optum.com/oihub/eligibility/v1/pre-service/member
OPTUM_PROVIDER_TAX_ID=448835440

# Anthropic Claude API
# Obtain at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Application Mode
# 'mock'       — Uses fixture data. No API keys needed, no login required.
# 'sandbox'    — Calls the real Optum sandbox + Anthropic APIs. Requires credentials above.
# 'production' — Calls live Optum production API.
NEXT_PUBLIC_APP_ENV=mock
